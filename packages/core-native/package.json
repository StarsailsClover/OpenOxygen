{
  "name": "@openoxygen/core-native",
  "version": "0.1.0",
  "description": "OpenOxygen Rust native core — NAPI-RS bindings",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "core-native",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
