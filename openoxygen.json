{
  "version": "0.1.0",
  "gateway": {
    "host": "127.0.0.1",
    "port": 4800,
    "auth": {
      "mode": "none"
    }
  },
  "security": {
    "privilegeLevel": "standard",
    "auditEnabled": true,
    "rollbackEnabled": true
  },
  "memory": {
    "backend": "builtin",
    "hybridSearch": true,
    "extraPaths": []
  },
  "vision": {
    "enabled": false
  },
  "models": [
    {
      "provider": "ollama",
      "model": "mock-qwen3-4b",
      "baseUrl": "http://127.0.0.1:11434/v1",
      "apiKey": "local",
      "temperature": 0.7,
      "maxTokens": 4096
    }
  ],
  "agents": {
    "default": "default",
    "list": [
      {
        "id": "default",
        "name": "OpenOxygen Default Agent"
      }
    ]
  },
  "channels": [],
  "plugins": []
}
