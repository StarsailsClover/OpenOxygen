{
  "name": "OpenOxygen",
  "version": "26w15aE",
  "description": "High-performance AI Agent Framework",
  "native": {
    "module": "./native/build/Release/openoxygen_native.node",
    "enabled": true
  },
  "llm": {
    "provider": "ollama",
    "endpoint": "http://localhost:11434",
    "model": "qwen3:4b",
    "fallbackModel": "qwen3:1.8b"
  },
  "agent": {
    "htn": {
      "enabled": true,
      "maxDepth": 5
    },
    "osr": {
      "enabled": true,
      "autoRecord": false
    }
  },
  "compat": {
    "openclaw": {
      "enabled": true,
      "autoMigrate": false
    }
  }
}
