/**
 * OpenOxygen - Task Orchestrator (Fixed)
 * 
 * 修复内容:
 * 1. 添加 instruction 参数类型检查和转换
 * 2. 确保 decomposeTask 接收字符串参数
 */

import { createSubsystemLogger } from "../../logging/index.js";
import { generateId, nowMs } from "../../utils/index.js";
import type { ExecutionMode } from "../../types/index.js";
import { delegateTask, updateTaskStatus, executeDelegatedTask, type DelegatedTask, type AgentDelegatedResult } from "../communication/index.js";
import { executeWithStrategy, type TaskStrategy } from "../../execution/unified/index.js";

const log = createSubsystemLogger("agent/orchestrator");

// Types

export type SubTask = {
  id: string;
  name: string;
  instruction: string;
  mode?: ExecutionMode;
  dependsOn?: string[];
  retryCount: number;
  maxRetries: number;
  timeoutMs: number;
  result?: AgentDelegatedResult;
  status: "pending" | "waiting" | "running" | "completed" | "failed" | "skipped";
  startedAt?: number;
  completedAt?: number;
};

export type OrchestratedTask = {
  id: string;
  name: string;
  instruction: string;
  subtasks: SubTask[];
  strategy: "sequential" | "parallel" | "dag";
  status: "pending" | "running" | "completed" | "failed" | "partial";
  createdAt: number;
  startedAt?: number;
  completedAt?: number;
  results: {
    success: number;
    failed: number;
    skipped: number;
    total: number;
  };
};

export type TaskPlan = {
  name: string;
  description: string;
  subtasks: Array<{
    name: string;
    instruction: string;
    mode?: ExecutionMode;
    dependsOn?: string[];
    maxRetries?: number;
    timeoutMs?: number;
  }>;
  strategy: "sequential" | "parallel" | "dag";
};

/**
 * 安全地提取字符串指令
 * 处理字符串、对象或其他类型的输入
 */
function extractInstruction(input: unknown): string {
  // 如果是字符串，直接使用
  if (typeof input === 'string') {
    return input;
  }
  
  // 如果是对象，尝试提取 instruction 属性
  if (input && typeof input === 'object') {
    const obj = input as Record<string, unknown>;
    
    if (typeof obj.instruction === 'string') {
      return obj.instruction;
    }
    if (typeof obj.text === 'string') {
      return obj.text;
    }
    if (typeof obj.command === 'string') {
      return obj.command;
    }
    if (typeof obj.query === 'string') {
      return obj.query;
    }
    if (typeof obj.name === 'string') {
      return obj.name;
    }
    
    // 尝试 toString
    if (typeof obj.toString === 'function') {
      const str = obj.toString();
      if (str !== '[object Object]') {
        return str;
      }
    }
  }
  
  log.warn(`Invalid instruction type in orchestrator: ${typeof input}`);
  return '';
}

/**
 * 基于关键词的任务分解
 * 修复: 添加类型检查
 */
export function decomposeTask(input: unknown): TaskPlan {
  const instruction = extractInstruction(input);
  
  // 空指令处理
  if (!instruction || instruction.trim() === '') {
    log.warn('Empty instruction in decomposeTask, returning default plan');
    return {
      name: "默认任务",
      description: "空指令",
      strategy: "sequential",
      subtasks: [
        { name: "等待输入", instruction: "echo '等待用户输入'", mode: "terminal" }
      ]
    };
  }
  
  const lower = instruction.toLowerCase();

  // 部署项目模式
  if (lower.includes("部署") || lower.includes("deploy") || lower.includes("发布")) {
    return {
      name: "部署项目",
      description: `部署: ${instruction}`,
      strategy: "sequential",
      subtasks: [
        { name: "构建", instruction: "npm run build", mode: "terminal", maxRetries: 1 },
        { name: "测试", instruction: "npm test", mode: "terminal", dependsOn: ["构建"], maxRetries: 2 },
        { name: "部署", instruction: "npm run deploy", mode: "terminal", dependsOn: ["测试"], maxRetries: 1 },
      ],
    };
  }

  // 代码审查模式
  if (lower.includes("审查") || lower.includes("review") || lower.includes("code review")) {
    return {
      name: "代码审查",
      description: `审查: ${instruction}`,
      strategy: "parallel",
      subtasks: [
        { name: "语法检查", instruction: "npm run lint", mode: "terminal" },
        { name: "类型检查", instruction: "npm run typecheck", mode: "terminal" },
        { name: "单元测试", instruction: "npm run test:unit", mode: "terminal" },
      ],
    };
  }

  // 默认: 单任务
  return {
    name: "执行任务",
    description: instruction,
    strategy: "sequential",
    subtasks: [
      { name: "执行", instruction, mode: "terminal" }
    ]
  };
}

