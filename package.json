{
  "name": "openoxygen-next",
  "version": "1.26.149",
  "description": "OpenOxygen Next - Vision-first Computer Use Agent with multi-agent orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:rust": "cargo build --release",
    "test": "jest",
    "test:rust": "cargo test",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist && cargo clean"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "gui",
    "cli",
    "llm",
    "computer-use",
    "ui-tars",
    "openclaw"
  ],
  "author": "OpenOxygen Team",
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "ws": "^8.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
