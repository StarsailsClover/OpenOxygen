# OpenOxygen .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs) or `~/.openoxygen/.env` (for services).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
OPENOXYGEN_GATEWAY_TOKEN=change-me-to-a-long-random-token
# OPENOXYGEN_GATEWAY_PORT=4800
# OPENOXYGEN_GATEWAY_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# OPENOXYGEN_STATE_DIR=~/.openoxygen
# OPENOXYGEN_CONFIG_PATH=~/.openoxygen/openoxygen.json

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# OPENOXYGEN_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Model Provider API Keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# STEPFUN_API_KEY=...

# Multiple keys for rotation:
# OPENAI_API_KEYS=sk-1,sk-2,sk-3
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2

# Custom provider:
# CUSTOM_MODEL_BASE_URL=http://localhost:8080/v1
# CUSTOM_MODEL_API_KEY=...

# -----------------------------------------------------------------------------
# OpenClaw Compatibility
# -----------------------------------------------------------------------------
# OPENOXYGEN_OPENCLAW_COMPAT=1
# OPENOXYGEN_OPENCLAW_CONFIG=~/.openclaw/openclaw.json

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# OPENOXYGEN_AUDIT_ENABLED=1
# OPENOXYGEN_PRIVILEGE_LEVEL=minimal

# -----------------------------------------------------------------------------
# Memory
# -----------------------------------------------------------------------------
# OPENOXYGEN_MEMORY_EXTRA_PATHS=/path/to/workspace1,/path/to/workspace2
# OPENOXYGEN_MEMORY_TTL_DAYS=30

# -----------------------------------------------------------------------------
# Vision (OxygenUltraVision)
# -----------------------------------------------------------------------------
# OPENOXYGEN_VISION_ENABLED=0
# OPENOXYGEN_VISION_CAPTURE_INTERVAL_MS=5000
